  { name: 'Nico Lang', affiliation: 'University of Copenhagen' },
  { name: 'Johannes Jakubik', affiliation: 'IBM' },
  { name: 'Valerio Marsocci', affiliation: 'ESA Φ-lab' },
  { name: 'Ruben Cartuyvels', affiliation: 'ESA Φ-lab' },
